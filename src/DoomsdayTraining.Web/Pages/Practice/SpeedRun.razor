    private async void AnswerYearDoomsday(Weekday answer)
    {
        if (answering) return;
        if (answer == calcYearDoomsday)
            await CorrectAnswer(PtsYearDoomsday);
        else
            WrongAnswer(6, $"{(int)answer} ({answer})", $"{(int)calcYearDoomsday} ({calcYearDoomsday})",
                $"{calcYearTotal} mod 7 = {(int)calcYearDoomsday} → {calcYearDoomsday}");
    }

    private async void AnswerMonthDoomsday(int answer)
    {
        if (answering) return;
        if (IsValidMonthDoomsdayAnswer(answer))
        {
            // Update reference to the date the user actually chose so subsequent
            // distance/mod-7 steps are consistent with their selection.
            calcDoomsdayInMonth = answer;
            calcDiff = currentDate.Day - calcDoomsdayInMonth;
            calcDiffMod7 = Math.Abs(calcDiff) % 7;

            // If the target day IS the doomsday, skip the redundant distance steps
            skipDistancePhases = calcDiff == 0;

            await CorrectAnswer(PtsMonthDoomsday);
        }
        else
            WrongAnswer(7, $"Den {answer}:e", GetValidMonthDoomsdayAnswersText(),
                $"{calcMonthInfo.MonthName}: {calcMonthInfo.Mnemonic}");
    }

    private async void AnswerDiff(int answer)
    {
        if (answering) return;
        if (answer == calcDiff)
            await CorrectAnswer(PtsDiff);
        else
            WrongAnswer(8, $"{answer}", $"{calcDiff}",
                $"{currentDate.Day} − {calcDoomsdayInMonth} = {calcDiff}");
    }

    private async void AnswerDiffMod7(int answer)
    {
        if (answering) return;
        if (answer == calcDiffMod7)
            await CorrectAnswer(PtsDiffMod7);
        else
            WrongAnswer(9, $"{answer}", $"{calcDiffMod7}",
                $"|{calcDiff}| mod 7 = {Math.Abs(calcDiff)} mod 7 = {calcDiffMod7}");
    }

    private async void AnswerFinalDay(Weekday answer)
    {
        if (answering) return;
        if (answer == calcFinalWeekday)
        {
            var pts = (selectedDifficulty == "expert" || skipDistancePhases)
                ? PtsDiff + PtsDiffMod7 + PtsFinalDay   // combined score when distance steps skipped
                : PtsFinalDay;
            await CorrectAnswer(pts);
        }
        else
        {
            var diffMod = ((calcDiff % 7) + 7) % 7;
            WrongAnswer(10, $"{answer}", $"{calcFinalWeekday}",
                $"{calcYearDoomsday}({(int)calcYearDoomsday}) + {calcDiff} dagar.\n" +
                $"{(int)calcYearDoomsday} + {calcDiff} = {(int)calcYearDoomsday + calcDiff}, mod 7 = {(int)calcFinalWeekday} → {calcFinalWeekday}");
        }
    }

    // ═══════════════════════════════════════════════
    // OPTION GENERATORS – smarta val för varje fas
    // ═══════════════════════════════════════════════

    private static readonly Random _rng = new();

    private static T[] Shuffle<T>(T[] arr)
    {
        for (var i = arr.Length - 1; i > 0; i--)
        {
            var j = _rng.Next(i + 1);
            (arr[i], arr[j]) = (arr[j], arr[i]);
        }
        return arr;
    }

    private int[] GetRemainderOptions()
    {
        var correct = calcRemainder;
        var options = new HashSet<int> { correct };
        if (IsHardOrExpert)
        {
            for (var i = 0; i <= 11; i++)
                options.Add(i);
        }
        else
        {
            for (var i = 0; i <= 11; i += 2)
                options.Add(i);
        }
        return Shuffle(options.OrderBy(x => x).ToArray());
    }

    private int[] GetSumOptions()
    {
        var correct = calcYearTotal;
        var options = new HashSet<int> { correct };
        var range = IsHardOrExpert ? 5 : 3;
        for (var delta = -range; delta <= range; delta++)
        {
            var v = correct + delta;
            if (v >= 0) options.Add(v);
        }
        if (correct >= 7) options.Add(correct - 7);
        options.Add(correct + 7);
        if (IsHardOrExpert)
        {
            if (correct >= 12) options.Add(correct - 12);
            options.Add(correct + 12);
        }
        return Shuffle(options.Where(x => x >= 0).OrderBy(x => x).ToArray());
    }

    private int[] GetMonthDoomsdayOptions()
    {
        var daysInMonth = DateTime.DaysInMonth(currentDate.Year, currentDate.Month);
        var canonical = calcDoomsdayInMonth;

        // All valid doomsday dates in this month (congruent mod 7)
        var validSet = new HashSet<int>(
            Enumerable.Range(1, daysInMonth).Where(d => ((d - canonical) % 7 + 7) % 7 == 0));

        var options = new HashSet<int>(validSet);

        // Always add wrong nearby dates as distractors
        int[] offsets = IsHardOrExpert ? [-3, -2, -1, 1, 2, 3] : [-2, -1, 1, 2];
        foreach (var valid in validSet)
        {
            foreach (var off in offsets)
            {
                var v = valid + off;
                if (v >= 1 && v <= daysInMonth && !validSet.Contains(v))
                    options.Add(v);
            }
        }

        // Month-specific extra distractors (common confusions)
        int[] extras = currentDate.Month switch
        {
            1 => [2, 5, 10],           // confuse with Feb or regular dates
            2 => [26, 27],             // close to 28/29
            3 => [3, 10, 17, 24],      // off-by-4 from 7,14,21,28
            5 => [7, 12],              // confuse with 7-Eleven rule
            7 => [4, 14],              // confuse with even-month rule
            9 => [9, 12],              // confuse with month number
            11 => [4, 11, 14],         // confuse with even-month rule
            _ => []
        };
        foreach (var e in extras)
        {
            if (e >= 1 && e <= daysInMonth && !validSet.Contains(e))
                options.Add(e);
        }

        // Hard/expert: ensure even more spread
        if (IsHardOrExpert)
        {
            foreach (var valid in validSet)
            {
                if (valid + 7 <= daysInMonth && !validSet.Contains(valid + 7)) options.Add(valid + 7);
                if (valid - 7 >= 1 && !validSet.Contains(valid - 7)) options.Add(valid - 7);
                if (valid + 4 <= daysInMonth) options.Add(valid + 4);
                if (valid - 4 >= 1) options.Add(valid - 4);
            }
        }

        return Shuffle(options.OrderBy(x => x).ToArray());
    }

    private int[] GetDiffOptions()
    {
        var correct = calcDiff;
        var options = new HashSet<int> { correct };
        var range = IsHardOrExpert ? 4 : 2;
        for (var delta = -range; delta <= range; delta++)
        {
            options.Add(correct + delta);
        }
        options.Add(-correct);
        if (correct != 0) options.Add(0);
        if (IsHardOrExpert)
        {
            options.Add(correct + 7);
            options.Add(correct - 7);
        }
        return Shuffle(options.OrderBy(x => x).ToArray());
    }

