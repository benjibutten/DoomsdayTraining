    // MEMORY TRAINING
    // ═══════════════════════════════════════════════

    private List<MemoryChipItem> GetMemoryItemsForPhase(int phase)
    {
        var items = new List<MemoryChipItem>();
        bool isExpert = selectedDifficulty == "expert";

        // Leap year: needed at phase 7 for Jan/Feb month doomsday
        if (currentDate.Month <= 2 && phase >= 1 && phase <= 7)
            items.Add(new("Skottår", calcIsLeapYear ? "Ja" : "Nej", phase == 7));

        // Century anchor number: needed at phase 5 (sum)
        if (phase >= 2 && phase <= 5)
            items.Add(new("Ankare", $"{(int)calcCenturyAnchor}", phase == 5));

        // Quotient: needed at phase 5 (sum)
        if (phase >= 3 && phase <= 5)
            items.Add(new("Kvot", $"{calcQuotient}", phase == 5));

        // Remainder: needed at phases 4 (leap adj) and 5 (sum)
        if (phase >= 4 && phase <= 5)
            items.Add(new("Rest", $"{calcRemainder}", phase == 5));

        // Leap adjustment: needed at phase 5 (sum) – only visible at phase 5
        if (phase == 5)
            items.Add(new("÷4", $"{calcLeapAdj}", true));

        // Sum: needed at phase 6 (mod 7)
        if (phase == 6)
            items.Add(new("Summa", $"{calcYearTotal}", true));

        // Year doomsday: needed at phase 10 (final day) – longest carry!
        if (phase >= 7 && phase <= 10)
            items.Add(new("Doom", $"{calcYearDoomsday}", phase == 10));

        // Month doomsday ref: needed at phase 8 (distance), or expert phase 10
        if (phase == 8 || (isExpert && phase == 10))
            items.Add(new("Ref", $"{calcDoomsdayInMonth}", true));

        // Diff: needed at phase 9 (mod 7)
        if (phase == 9)
            items.Add(new("Δ", $"{calcDiff}", true));

        // DiffMod7: needed at phase 10 (final day)
        if (phase == 10 && !isExpert)
            items.Add(new("m7", $"{calcDiffMod7}", true));

        return items;
    }

    private async Task HideMemorizeFlashAsync()
    {
        await Task.Delay(MemorizeFlashMs);
        memorizeFlashFading = true;
        StateHasChanged();
        await Task.Delay(MemorizeFadeMs);
        showMemorizeFlash = false;
        memorizeFlashFading = false;
        StateHasChanged();
    }

