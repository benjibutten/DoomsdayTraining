    private static bool IsFrotsCentury(int year)
    {
        var c = year / 100;
        return c >= FrotsCenturyMin && c <= FrotsCenturyMax;
    }

    private bool IsValidMonthDoomsdayAnswer(int day)
    {
        if (day < 1 || day > DateTime.DaysInMonth(currentDate.Year, currentDate.Month))
            return false;

        var delta = day - calcDoomsdayInMonth;
        return ((delta % 7) + 7) % 7 == 0;
    }

    private string GetValidMonthDoomsdayAnswersText()
    {
        var daysInMonth = DateTime.DaysInMonth(currentDate.Year, currentDate.Month);
        var validDays = Enumerable.Range(1, daysInMonth)
            .Where(IsValidMonthDoomsdayAnswer)
            .ToArray();

        return validDays.Length == 1
            ? $"Den {validDays[0]}:e"
            : string.Join(", ", validDays.Select(day => $"Den {day}:e"));
    }

