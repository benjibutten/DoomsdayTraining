    private bool IsHardOrExpert => selectedDifficulty is "hard" or "expert";
    private bool ShowExpertPeekButton => selectedDifficulty == "expert" && !phasePeeked;

    private void PeekPhase()
    {
        if (!phasePeeked)
        {
            phasePeeked = true;
            totalPoints = Math.Max(0, totalPoints - PeekCost);
        }
    }

    private void PeekSummary()
    {
        if (!summaryPeeked)
        {
            summaryPeeked = true;
            totalPoints = Math.Max(0, totalPoints - SummaryPeekCost);
        }
    }
