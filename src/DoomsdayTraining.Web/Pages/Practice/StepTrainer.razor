@page "/practice/step-trainer"

<PageTitle>Steg-för-steg-träning – Doomsday-Algoritmen</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">🧩 Steg-för-steg-träning</MudText>
<MudText Typo="Typo.subtitle1" Class="mb-4">Välj vilket delmoment du vill öva på, och träna tills det sitter!</MudText>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-3">⚙️ Välj övning</MudText>
    <div class="d-flex gap-2 flex-wrap">
        <MudButton Variant="@(mode == TrainingMode.CenturyAnchor ? Variant.Filled : Variant.Outlined)"
                   Color="Color.Primary" OnClick="() => SetMode(TrainingMode.CenturyAnchor)"
                   StartIcon="@Icons.Material.Filled.AccountBalance" Size="Size.Small">Sekelankare</MudButton>
        <MudButton Variant="@(mode == TrainingMode.YearDoomsday ? Variant.Filled : Variant.Outlined)"
                   Color="Color.Primary" OnClick="() => SetMode(TrainingMode.YearDoomsday)"
                   StartIcon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small">Årets Doomsday</MudButton>
        <MudButton Variant="@(mode == TrainingMode.MonthDoomsday ? Variant.Filled : Variant.Outlined)"
                   Color="Color.Primary" OnClick="() => SetMode(TrainingMode.MonthDoomsday)"
                   StartIcon="@Icons.Material.Filled.ListAlt" Size="Size.Small">Månadsdatum</MudButton>
        <MudButton Variant="@(mode == TrainingMode.FullAlgorithm ? Variant.Filled : Variant.Outlined)"
                   Color="Color.Secondary" OnClick="() => SetMode(TrainingMode.FullAlgorithm)"
                   StartIcon="@Icons.Material.Filled.Route" Size="Size.Small">Hela algoritmen</MudButton>
    </div>
</MudPaper>

@if (mode != TrainingMode.None)
{
    <MudGrid Spacing="2" Class="mb-3">
        <MudItem xs="4" sm="2">
            <MudPaper Elevation="1" Class="pa-2 pa-sm-3 text-center">
                <MudText Typo="Typo.h5">@answered</MudText>
                <MudText Typo="Typo.caption">SVAR</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="4" sm="2">
            <MudPaper Elevation="1" Class="pa-2 pa-sm-3 text-center">
                <MudText Typo="Typo.h5" Color="Color.Success">@correct</MudText>
                <MudText Typo="Typo.caption">RÄTT</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="4" sm="2">
            <MudPaper Elevation="1" Class="pa-2 pa-sm-3 text-center">
                <MudText Typo="Typo.h5">@(answered > 0 ? $"{(int)(correct * 100.0 / answered)}%" : "–")</MudText>
                <MudText Typo="Typo.caption">TRÄFFSÄKERHET</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @if (streak.Count > 0)
    {
        <div class="d-flex gap-1 flex-wrap mb-3">
            @foreach (var r in streak.TakeLast(20))
            {
                <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small"
                         Color="@(r ? Color.Success : Color.Error)" />
            }
        </div>
    }
}

@* ──── SEKELANKARE-ÖVNING ──── *@
@if (mode == TrainingMode.CenturyAnchor)
{
    <MudPaper Elevation="4" Class="pa-4 pa-sm-6 text-center mx-auto mb-4" Style="max-width:520px; border-radius:16px;" @key="questionKey">
        <MudText Typo="Typo.body2" Class="mb-1">Vilket sekelankare har...</MudText>
        <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-3">@(centuryYear)-talet</MudText>

        @if (hasAnswered)
        {
            @if (wasCorrect)
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-3">
                    ✅ Rätt! @centuryYear-talet = <strong>@centuryCorrectAnswer</strong>.
                </MudAlert>
            }
            else
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
                    ❌ Fel. Du svarade @centuryUserAnswer. Rätt: <strong>@centuryCorrectAnswer</strong>.
                </MudAlert>
            }
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-3">
                <strong>FrOTS:</strong> <strong>Fr</strong>edag (1800) → <strong>O</strong>nsdag (1900) → <strong>T</strong>isdag (2000) → <strong>S</strong>öndag (2100)
            </MudAlert>
            <MudGrid Spacing="2" Justify="Justify.Center" Class="mb-3">
                @foreach (Weekday day in Enum.GetValues<Weekday>())
                {
                    var color = day == centuryCorrectAnswer ? Color.Success
                              : (day == centuryUserAnswer && !wasCorrect) ? Color.Error
                              : Color.Default;
                    var variant = (day == centuryCorrectAnswer || (day == centuryUserAnswer && !wasCorrect)) ? Variant.Filled : Variant.Outlined;
                    <MudItem xs="4" sm="3">
                        <MudButton FullWidth="true" Variant="@variant" Color="@color" Disabled="true" Size="Size.Small">@day</MudButton>
                    </MudItem>
                }
            </MudGrid>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NextQuestion" EndIcon="@Icons.Material.Filled.ArrowForward">Nästa</MudButton>
        }
        else
        {
            <MudGrid Spacing="2" Justify="Justify.Center">
                @foreach (Weekday day in Enum.GetValues<Weekday>())
                {
                    var d = day;
                    <MudItem xs="4" sm="3">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="() => AnswerCentury(d)" Size="Size.Small">@d</MudButton>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudPaper>
}

@* ──── ÅRETS DOOMSDAY-ÖVNING ──── *@
@if (mode == TrainingMode.YearDoomsday)
{
    <MudPaper Elevation="4" Class="pa-4 pa-sm-6 text-center mx-auto mb-4" Style="max-width:520px; border-radius:16px;" @key="questionKey">
        <MudText Typo="Typo.body2" Class="mb-1">Vilken veckodag är Doomsday för år...</MudText>
        <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-2">@yearToGuess</MudText>
        <MudText Typo="Typo.body2" Class="mb-3">Sekelankare: <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">@yearCenturyAnchor</MudChip></MudText>

        @if (hasAnswered)
        {
            var yy = yearToGuess % 100;
            var yQuot = yy / 12;
            var yRem = yy % 12;
            var yLeap = yRem / 4;
            var ySum = (int)yearCenturyAnchor + yQuot + yRem + yLeap;

            @if (wasCorrect)
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-3">
                    ✅ Rätt! Doomsday @yearToGuess = <strong>@yearCorrectAnswer</strong>.
                </MudAlert>
            }
            else
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
                    ❌ Fel. Du svarade @yearUserAnswer. Rätt: <strong>@yearCorrectAnswer</strong>.
                </MudAlert>
            }

            <MudGrid Spacing="2" Justify="Justify.Center" Class="mb-3">
                @foreach (Weekday day in Enum.GetValues<Weekday>())
                {
                    var color = day == yearCorrectAnswer ? Color.Success
                              : (day == yearUserAnswer && !wasCorrect) ? Color.Error
                              : Color.Default;
                    var variant = (day == yearCorrectAnswer || (day == yearUserAnswer && !wasCorrect)) ? Variant.Filled : Variant.Outlined;
                    <MudItem xs="4" sm="3">
                        <MudButton FullWidth="true" Variant="@variant" Color="@color" Disabled="true" Size="Size.Small">@day</MudButton>
                    </MudItem>
                }
            </MudGrid>

            <MudPaper Elevation="0" Class="pa-3 mb-3 text-left" Style="background:var(--mud-palette-background-gray,#f5f5f5); border-radius:6px; font-size:0.9rem;">
                <MudText Typo="Typo.caption" Class="mb-1"><strong>Steg-för-steg (y = @yy):</strong></MudText>
                <div>a) 12-årsblock: @yy ÷ 12 = <strong>@yQuot</strong></div>
                <div>b) Överblivna år: @yy mod 12 = <strong>@yRem</strong></div>
                <div>c) Skottårshopp: @yRem ÷ 4 = <strong>@yLeap</strong></div>
                <div>d) Summa: @((int)yearCenturyAnchor) + @yQuot + @yRem + @yLeap = @ySum → mod 7 = <strong>@yearCorrectAnswer</strong></div>
            </MudPaper>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NextQuestion" EndIcon="@Icons.Material.Filled.ArrowForward">Nästa</MudButton>
        }
        else
        {
            <MudGrid Spacing="2" Justify="Justify.Center">
                @foreach (Weekday day in Enum.GetValues<Weekday>())
                {
                    var d = day;
                    <MudItem xs="4" sm="3">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="() => AnswerYear(d)" Size="Size.Small">@d</MudButton>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudPaper>
}

@* ──── MÅNADSDATUM-ÖVNING ──── *@
@if (mode == TrainingMode.MonthDoomsday)
{
    <MudPaper Elevation="4" Class="pa-4 pa-sm-6 text-center mx-auto mb-4" Style="max-width:520px; border-radius:16px;" @key="questionKey">
        <MudText Typo="Typo.body2" Class="mb-1">Vilket datum är Doomsday i...</MudText>
        <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-2">@monthInfo!.MonthName</MudText>
        @if (monthIsLeapYear && (monthInfo!.Month == 1 || monthInfo.Month == 2))
        {
            <MudText Typo="Typo.body2" Class="mb-3">(skottår)</MudText>
        }
        else if (!monthIsLeapYear && (monthInfo!.Month == 1 || monthInfo.Month == 2))
        {
            <MudText Typo="Typo.body2" Class="mb-3">(vanligt år)</MudText>
        }

        @if (hasAnswered)
        {
            @if (wasCorrect)
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-3">
                    ✅ Rätt! I @monthInfo!.MonthName fungerar <strong>@GetMonthDoomsdayAnswersText(monthInfo!.Month, monthIsLeapYear)</strong> som Doomsday-datum.
                </MudAlert>
            }
            else
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">
                    ❌ Fel. Du svarade @monthUserDay:e. Giltiga svar: <strong>@GetMonthDoomsdayAnswersText(monthInfo!.Month, monthIsLeapYear)</strong>.
                </MudAlert>
            }
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3 text-left">@monthInfo!.Mnemonic</MudAlert>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NextQuestion" EndIcon="@Icons.Material.Filled.ArrowForward">Nästa</MudButton>
        }
        else
        {
            <div class="d-flex gap-2 align-center justify-center mt-3">
                <MudSelect @bind-Value="monthUserDay" Label="Dag i månaden" Variant="Variant.Outlined" Style="min-width:160px; max-width:200px;">
                    <MudSelectItem Value="@NoDaySelected" Disabled="true">@SelectDayPlaceholder</MudSelectItem>
                    @foreach (var day in GetDayOptions(monthInfo!.Month, monthIsLeapYear))
                    {
                        <MudSelectItem Value="@day">@FormatOrdinalDay(day)</MudSelectItem>
                    }
                </MudSelect>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AnswerMonth" Class="align-self-center" Disabled="@(monthUserDay == NoDaySelected)">Svara</MudButton>
            </div>
        }
    </MudPaper>
}

@* ──── HELA ALGORITMEN-ÖVNING ──── *@
@if (mode == TrainingMode.FullAlgorithm)
{
    <MudPaper Elevation="4" Class="pa-4 pa-sm-6 mx-auto mb-4" Style="max-width:600px; border-radius:16px;" @key="questionKey">
        <MudText Typo="Typo.body2" Class="text-center mb-1">Beräkna veckodagen för...</MudText>
        <MudText Typo="Typo.h4" Color="Color.Primary" Class="text-center mb-4" Style="font-variant-numeric: tabular-nums;">
            @fullDate.ToString("d MMMM yyyy", SwedishCulture)
        </MudText>

        @* Progressindikator *@
        <div class="d-flex gap-2 mb-4 justify-center">
            @for (var s = 0; s < 4; s++)
            {
                var stepNum = s;
                var isActive = fullStep == stepNum;
                var isDone = fullStep > stepNum || fullCompleted;
                var hasError = fullStepErrors.ContainsKey(stepNum);
                var stepLabel = GetStepLabel(stepNum);
                <MudChip T="string" Size="Size.Small"
                         Color="@(hasError ? Color.Error : isDone ? Color.Success : isActive ? Color.Primary : Color.Default)"
                         Variant="@(isActive || isDone ? Variant.Filled : Variant.Outlined)">
                    @(stepNum + 1). @stepLabel
                </MudChip>
            }
        </div>

        @* Steg 1: Sekelankare *@
        @if (fullStep == 0 && !fullCompleted)
        {
            <MudText Typo="Typo.body1" Class="mb-3">Vilket sekelankare (veckodag) har <strong>@(fullDate.Year / 100 * 100)-talet</strong>?</MudText>
            <MudGrid Spacing="2" Justify="Justify.Center">
                @foreach (Weekday day in Enum.GetValues<Weekday>())
                {
                    var d = day;
                    var isSelected = fullStepCenturyAnswer == d;
                    <MudItem xs="4" sm="3">
                        <MudButton FullWidth="true"
                                   Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                                   Color="@(isSelected ? Color.Primary : Color.Default)"
                                   OnClick="() => fullStepCenturyAnswer = d"
                                   Size="Size.Small">@d</MudButton>
                    </MudItem>
                }
            </MudGrid>
            @if (fullStepErrors.ContainsKey(0))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mt-2">@fullStepErrors[0]</MudAlert>
            }
            <div class="text-center mt-3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitFullStep"
                           EndIcon="@Icons.Material.Filled.ArrowForward">Nästa steg</MudButton>
            </div>
        }

        @* Steg 2: Årets Doomsday *@
        @if (fullStep == 1 && !fullCompleted)
        {
            <MudText Typo="Typo.body1" Class="mb-2">
                Sekelankare: <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">@fullCenturyCorrect</MudChip>
            </MudText>
            <MudText Typo="Typo.body1" Class="mb-3">Vilken veckodag är Doomsday för år <strong>@fullDate.Year</strong>?</MudText>
            <MudGrid Spacing="2" Justify="Justify.Center">
                @foreach (Weekday day in Enum.GetValues<Weekday>())
                {
                    var d = day;
                    var isSelected = fullStepYearAnswer == d;
                    <MudItem xs="4" sm="3">
                        <MudButton FullWidth="true"
                                   Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                                   Color="@(isSelected ? Color.Primary : Color.Default)"
                                   OnClick="() => fullStepYearAnswer = d"
                                   Size="Size.Small">@d</MudButton>
                    </MudItem>
                }
            </MudGrid>
            @if (fullStepErrors.ContainsKey(1))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mt-2">@fullStepErrors[1]</MudAlert>
            }
            <div class="text-center mt-3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitFullStep"
                           EndIcon="@Icons.Material.Filled.ArrowForward">Nästa steg</MudButton>
            </div>
        }

        @* Steg 3: Månadsdatum *@
        @if (fullStep == 2 && !fullCompleted)
        {
            <MudText Typo="Typo.body1" Class="mb-2">
                Årets Doomsday: <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">@fullYearCorrect</MudChip>
            </MudText>
            <MudText Typo="Typo.body1" Class="mb-3">
                Vilket datum i <strong>@SwedishCulture.DateTimeFormat.GetMonthName(fullDate.Month)</strong>
                är Doomsday-referensen?
                @if (fullDate.Month == 1 || fullDate.Month == 2)
                {
                    <span> (@(LeapYearChecker.IsLeapYear(fullDate.Year) ? "skottår" : "vanligt år"))</span>
                }
            </MudText>
            <div class="d-flex gap-2 align-center justify-center">
                <MudSelect @bind-Value="fullStepMonthDay" Label="Dag" Variant="Variant.Outlined" Style="min-width:140px; max-width:180px;">
                    <MudSelectItem Value="@NoDaySelected" Disabled="true">@SelectDayPlaceholder</MudSelectItem>
                    @foreach (var day in GetDayOptions(fullDate.Month, LeapYearChecker.IsLeapYear(fullDate.Year)))
                    {
                        <MudSelectItem Value="@day">@FormatOrdinalDay(day)</MudSelectItem>
                    }
                </MudSelect>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitFullStep"
                           EndIcon="@Icons.Material.Filled.ArrowForward" Class="align-self-center" Disabled="@(fullStepMonthDay == NoDaySelected)">Nästa steg</MudButton>
            </div>
            @if (fullStepErrors.ContainsKey(2))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mt-2">@fullStepErrors[2]</MudAlert>
            }
        }

        @* Steg 4: Slutgiltig veckodag *@
        @if (fullStep == 3 && !fullCompleted)
        {
            <MudText Typo="Typo.body1" Class="mb-2">
                Doomsday = <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">@fullYearCorrect</MudChip>,
                Referensdatum = den <strong>@fullMonthDayCorrect:e</strong>
            </MudText>
            <MudText Typo="Typo.body1" Class="mb-3">Vilken veckodag är <strong>@fullDate.ToString("d MMMM yyyy", SwedishCulture)</strong>?</MudText>
            <MudGrid Spacing="2" Justify="Justify.Center">
                @foreach (Weekday day in Enum.GetValues<Weekday>())
                {
                    var d = day;
                    var isSelected = fullStepFinalAnswer == d;
                    <MudItem xs="4" sm="3">
                        <MudButton FullWidth="true"
                                   Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                                   Color="@(isSelected ? Color.Primary : Color.Default)"
                                   OnClick="() => fullStepFinalAnswer = d"
                                   Size="Size.Small">@d</MudButton>
                    </MudItem>
                }
            </MudGrid>
            @if (fullStepErrors.ContainsKey(3))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mt-2">@fullStepErrors[3]</MudAlert>
            }
            <div class="text-center mt-3">
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="SubmitFullStep"
                           EndIcon="@Icons.Material.Filled.Check">Kontrollera</MudButton>
            </div>
        }

        @if (fullCompleted)
        {
            var resultText = $"{fullDate.ToString("d MMMM yyyy", SwedishCulture)} är en {fullFinalCorrect}.";
            <MudAlert Severity="@(fullAllCorrect ? Severity.Success : Severity.Warning)" Variant="Variant.Filled"
                      Class="mt-4 text-center">
                @if (fullAllCorrect)
                {
                    <strong>🎉 Alla steg rätt!</strong>
                    <span>@resultText</span>
                }
                else
                {
                    <strong>Rätt svar:</strong>
                    <span>@resultText</span>
                }
            </MudAlert>
            <div class="text-center mt-3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NextQuestion" EndIcon="@Icons.Material.Filled.ArrowForward">Nytt datum</MudButton>
            </div>
        }
    </MudPaper>
}

@code {
    private const int NoDaySelected = 0;
    private const int FirstDayOfMonth = 1;
    private const int RandomMonthUpperBoundExclusive = 13;
    private const int LeapYearCoinFlipUpperBoundExclusive = 2;
    private const int RandomYearStart = 1800;
    private const int RandomYearEndExclusive = 2200;
    private const int RandomYearEndInclusive = RandomYearEndExclusive - 1;
    private const string SelectDayPlaceholder = "Välj dag";
    private const string SwedishOrdinalSuffix = ":e";
    private const string SwedishSingleDayPrefix = "den ";
    private const string SwedishListSeparator = ", ";
    private const string SwedishFinalSeparator = " och ";

    private static readonly System.Globalization.CultureInfo SwedishCulture = new("sv-SE");
    private static readonly int[] SupportedCenturyYears = [1800, 1900, 2000, 2100];

    private enum TrainingMode { None, CenturyAnchor, YearDoomsday, MonthDoomsday, FullAlgorithm }

    private TrainingMode mode = TrainingMode.None;
    private int questionKey;
    private bool hasAnswered;
    private bool wasCorrect;
    private int answered;
    private int correct;
    private List<bool> streak = [];
    private static readonly Random _random = new();

    // Century
    private int centuryYear;
    private Weekday centuryCorrectAnswer;
    private Weekday centuryUserAnswer;

    // Year
    private int yearToGuess;
    private Weekday yearCenturyAnchor;
    private Weekday yearCorrectAnswer;
    private Weekday yearUserAnswer;

    // Month
    private MonthDoomsdayInfo? monthInfo;
    private bool monthIsLeapYear;
    private int monthUserDay;

    // Full Algorithm
    private DateOnly fullDate;
    private int fullStep;
    private Weekday? fullStepCenturyAnswer;
    private Weekday? fullStepYearAnswer;
    private int fullStepMonthDay;
    private Weekday? fullStepFinalAnswer;
    private Weekday fullCenturyCorrect;
    private Weekday fullYearCorrect;
    private int fullMonthDayCorrect;
    private Weekday fullFinalCorrect;
    private bool fullCompleted;
    private bool fullAllCorrect;
    private Dictionary<int, string> fullStepErrors = new();

    private void SetMode(TrainingMode newMode)
    {
        mode = newMode;
        answered = 0;
        correct = 0;
        streak.Clear();
        NextQuestion();
    }

    private void NextQuestion()
    {
        hasAnswered = false;
        wasCorrect = false;
        questionKey++;

        switch (mode)
        {
            case TrainingMode.CenturyAnchor:
                centuryYear = SupportedCenturyYears[_random.Next(SupportedCenturyYears.Length)];
                centuryCorrectAnswer = CenturyAnchorCalculator.Calculate(centuryYear);
                break;

            case TrainingMode.YearDoomsday:
                yearToGuess = _random.Next(RandomYearStart, RandomYearEndExclusive);
                yearCenturyAnchor = CenturyAnchorCalculator.Calculate(yearToGuess);
                yearCorrectAnswer = YearDoomsdayCalculator.Calculate(yearToGuess, yearCenturyAnchor);
                break;

            case TrainingMode.MonthDoomsday:
                var month = _random.Next(FirstDayOfMonth, RandomMonthUpperBoundExclusive);
                monthInfo = MonthDoomsdayProvider.GetInfoForMonth(month);
                monthIsLeapYear = _random.Next(LeapYearCoinFlipUpperBoundExclusive) == 0;
                monthUserDay = NoDaySelected;
                break;

            case TrainingMode.FullAlgorithm:
                fullDate = RandomDateGenerator.Generate(RandomYearStart, RandomYearEndInclusive);
                fullCenturyCorrect = CenturyAnchorCalculator.Calculate(fullDate.Year);
                fullYearCorrect = YearDoomsdayCalculator.Calculate(fullDate.Year, fullCenturyCorrect);
                fullMonthDayCorrect = MonthDoomsdayProvider.GetDoomsdayForMonth(fullDate.Month, LeapYearChecker.IsLeapYear(fullDate.Year));
                fullFinalCorrect = DoomsdayAlgorithm.GetWeekday(fullDate);
                fullStep = 0;
                fullStepCenturyAnswer = null;
                fullStepYearAnswer = null;
                fullStepMonthDay = NoDaySelected;
                fullStepFinalAnswer = null;
                fullCompleted = false;
                fullAllCorrect = true;
                fullStepErrors.Clear();
                break;
        }
    }

    private void SubmitFullStep()
    {
        fullStepErrors.Remove(fullStep);

        switch (fullStep)
        {
            case 0:
                if (fullStepCenturyAnswer is null)
                {
                    fullStepErrors[0] = "Välj en veckodag.";
                    return;
                }
                if (fullStepCenturyAnswer != fullCenturyCorrect)
                {
                    fullStepErrors[0] = $"Fel! Rätt svar: {fullCenturyCorrect}.";
                    fullAllCorrect = false;
                }
                RecordAnswer(fullStepCenturyAnswer == fullCenturyCorrect);
                fullStep = 1;
                break;

            case 1:
                if (fullStepYearAnswer is null)
                {
                    fullStepErrors[1] = "Välj en veckodag.";
                    return;
                }
                if (fullStepYearAnswer != fullYearCorrect)
                {
                    fullStepErrors[1] = $"Fel! Rätt svar: {fullYearCorrect}.";
                    fullAllCorrect = false;
                }
                RecordAnswer(fullStepYearAnswer == fullYearCorrect);
                fullStep = 2;
                break;

            case 2:
                if (fullStepMonthDay == NoDaySelected)
                {
                    fullStepErrors[2] = "Ange ett datum.";
                    return;
                }
                var isValidMonthAnswer = MonthDoomsdayProvider.IsValidDoomsdayDateForMonth(fullDate.Month, fullStepMonthDay, LeapYearChecker.IsLeapYear(fullDate.Year));
                if (!isValidMonthAnswer)
                {
                    fullStepErrors[2] = $"Fel! Giltiga svar: {GetMonthDoomsdayAnswersText(fullDate.Month, LeapYearChecker.IsLeapYear(fullDate.Year))}.";
                    fullAllCorrect = false;
                }
                else
                {
                    fullMonthDayCorrect = fullStepMonthDay;
                }
                RecordAnswer(isValidMonthAnswer);
                fullStep = 3;
                break;

            case 3:
                if (fullStepFinalAnswer is null)
                {
                    fullStepErrors[3] = "Välj en veckodag.";
                    return;
                }
                if (fullStepFinalAnswer != fullFinalCorrect)
                {
                    fullStepErrors[3] = $"Fel! Rätt svar: {fullFinalCorrect}.";
                    fullAllCorrect = false;
                }
                RecordAnswer(fullStepFinalAnswer == fullFinalCorrect);
                fullCompleted = true;
                break;
        }
    }

    private void RecordAnswer(bool isCorrect)
    {
        hasAnswered = true;
        wasCorrect = isCorrect;
        answered++;
        if (isCorrect) correct++;
        streak.Add(isCorrect);
    }

    private void AnswerCentury(Weekday answer)
    {
        centuryUserAnswer = answer;
        RecordAnswer(answer == centuryCorrectAnswer);
    }

    private void AnswerYear(Weekday answer)
    {
        yearUserAnswer = answer;
        RecordAnswer(answer == yearCorrectAnswer);
    }

    private void AnswerMonth()
    {
        if (monthInfo is null)
            return;

        RecordAnswer(MonthDoomsdayProvider.IsValidDoomsdayDateForMonth(monthInfo.Month, monthUserDay, monthIsLeapYear));
    }

    private static IEnumerable<int> GetDayOptions(int month, bool isLeapYear)
    {
        return Enumerable.Range(FirstDayOfMonth, MonthDoomsdayProvider.GetDaysInMonth(month, isLeapYear));
    }

    private static string GetMonthDoomsdayAnswersText(int month, bool isLeapYear)
    {
        return FormatDayList(MonthDoomsdayProvider.GetValidDoomsdayDatesForMonth(month, isLeapYear));
    }

    private static string FormatDayList(IReadOnlyList<int> days)
    {
        var formattedDays = days.Select(FormatOrdinalDay).ToArray();

        return formattedDays.Length switch
        {
            0 => "",
            1 => SwedishSingleDayPrefix + formattedDays[0],
            2 => formattedDays[0] + SwedishFinalSeparator + formattedDays[1],
            _ => string.Join(SwedishListSeparator, formattedDays[..^1]) + SwedishFinalSeparator + formattedDays[^1]
        };
    }

    private static string FormatOrdinalDay(int day) => $"{day}{SwedishOrdinalSuffix}";

    private static string GetStepLabel(int step) => step switch
    {
        0 => "Sekel",
        1 => "År",
        2 => "Månad",
        _ => "Dag"
    };
}
