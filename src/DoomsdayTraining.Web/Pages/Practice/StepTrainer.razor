@page "/practice/step-trainer"

<PageTitle>Steg-för-steg-träning – Doomsday-Algoritmen</PageTitle>

<div class="page-header">
    <h1>🧩 Steg-för-steg-träning</h1>
    <p>Välj vilket delmoment du vill öva på, och träna tills det sitter!</p>
</div>

<div class="card">
    <div class="card-header-custom">⚙️ Välj övning</div>
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn @(mode == TrainingMode.CenturyAnchor ? "btn-primary" : "btn-outline-primary")"
                @onclick="() => SetMode(TrainingMode.CenturyAnchor)">
            🏛️ Sekelankare
        </button>
        <button class="btn @(mode == TrainingMode.YearDoomsday ? "btn-primary" : "btn-outline-primary")"
                @onclick="() => SetMode(TrainingMode.YearDoomsday)">
            📅 Årets Doomsday
        </button>
        <button class="btn @(mode == TrainingMode.MonthDoomsday ? "btn-primary" : "btn-outline-primary")"
                @onclick="() => SetMode(TrainingMode.MonthDoomsday)">
            📋 Månadsdatum
        </button>
    </div>
</div>

@if (mode != TrainingMode.None)
{
    <!-- Statistik -->
    <div class="stats-bar">
        <div class="stat-item">
            <div class="stat-value">@answered</div>
            <div class="stat-label">Svar</div>
        </div>
        <div class="stat-item">
            <div class="stat-value text-success-custom">@correct</div>
            <div class="stat-label">Rätt</div>
        </div>
        <div class="stat-item">
            <div class="stat-value">@(answered > 0 ? $"{(int)(correct * 100.0 / answered)}%" : "–")</div>
            <div class="stat-label">Träffsäkerhet</div>
        </div>
    </div>

    <div class="streak">
        @foreach (var r in streak.TakeLast(20))
        {
            <div class="streak-dot @(r ? "correct" : "incorrect")"></div>
        }
    </div>
}

@* ──── SEKELANKARE-ÖVNING ──── *@
@if (mode == TrainingMode.CenturyAnchor)
{
    <div class="flashcard fade-in" @key="questionKey">
        <div style="font-size: 1rem; color: var(--text-muted);">Vilket sekelankare har...</div>
        <div class="flashcard-date">@(centuryYear)-talet</div>

        @if (hasAnswered)
        {
            @if (wasCorrect)
            {
                <div class="success-box">✅ Rätt! @centuryYear-talet har ankardagen <strong>@centuryCorrectAnswer</strong>.</div>
            }
            else
            {
                <div class="danger-box">❌ Fel. Du svarade @centuryUserAnswer. Rätt svar: <strong>@centuryCorrectAnswer</strong>.</div>
            }
            <div class="weekday-grid" style="margin-top: 1rem;">
                @foreach (Weekday day in Enum.GetValues<Weekday>())
                {
                    var cssClass = "weekday-btn";
                    if (day == centuryCorrectAnswer) cssClass += " correct";
                    else if (day == centuryUserAnswer && !wasCorrect) cssClass += " incorrect";
                    <button class="@cssClass" disabled>@day</button>
                }
            </div>
            <button class="btn btn-primary mt-2" @onclick="NextQuestion">Nästa →</button>
        }
        else
        {
            <div class="weekday-grid" style="margin-top: 1.5rem;">
                @foreach (Weekday day in Enum.GetValues<Weekday>())
                {
                    var d = day;
                    <button class="weekday-btn" @onclick="() => AnswerCentury(d)">@d</button>
                }
            </div>
        }
    </div>
}

@* ──── ÅRETS DOOMSDAY-ÖVNING ──── *@
@if (mode == TrainingMode.YearDoomsday)
{
    <div class="flashcard fade-in" @key="questionKey">
        <div style="font-size: 1rem; color: var(--text-muted);">Vilken veckodag är Doomsday för år...</div>
        <div class="flashcard-date">@yearToGuess</div>
        <div class="flashcard-hint">
            Sekelankare: <span class="badge-weekday">@yearCenturyAnchor</span>
        </div>

        @if (hasAnswered)
        {
            @if (wasCorrect)
            {
                <div class="success-box">✅ Rätt! Doomsday @yearToGuess = <strong>@yearCorrectAnswer</strong>.</div>
            }
            else
            {
                <div class="danger-box">❌ Fel. Du svarade @yearUserAnswer. Rätt: <strong>@yearCorrectAnswer</strong>.</div>
            }

            <div class="weekday-grid" style="margin-top: 1rem;">
                @foreach (Weekday day in Enum.GetValues<Weekday>())
                {
                    var cssClass = "weekday-btn";
                    if (day == yearCorrectAnswer) cssClass += " correct";
                    else if (day == yearUserAnswer && !wasCorrect) cssClass += " incorrect";
                    <button class="@cssClass" disabled>@day</button>
                }
            </div>

            <div class="tip-box" style="text-align: left; margin-top: 1rem;">
                <strong>Beräkning:</strong> y = @(yearToGuess % 100) →
                @(yearToGuess % 100) ÷ 12 = @(yearToGuess % 100 / 12) rest @(yearToGuess % 100 % 12) →
                @(yearToGuess % 100 % 12) ÷ 4 = @(yearToGuess % 100 % 12 / 4) →
                @((int)yearCenturyAnchor) + @(yearToGuess % 100 / 12) + @(yearToGuess % 100 % 12) + @(yearToGuess % 100 % 12 / 4) = @((int)yearCenturyAnchor + yearToGuess % 100 / 12 + yearToGuess % 100 % 12 + yearToGuess % 100 % 12 / 4)
                → mod 7 = @((int)yearCorrectAnswer) = @yearCorrectAnswer
            </div>
            <button class="btn btn-primary mt-2" @onclick="NextQuestion">Nästa →</button>
        }
        else
        {
            <div class="weekday-grid" style="margin-top: 1.5rem;">
                @foreach (Weekday day in Enum.GetValues<Weekday>())
                {
                    var d = day;
                    <button class="weekday-btn" @onclick="() => AnswerYear(d)">@d</button>
                }
            </div>
        }
    </div>
}

@* ──── MÅNADSDATUM-ÖVNING ──── *@
@if (mode == TrainingMode.MonthDoomsday)
{
    <div class="flashcard fade-in" @key="questionKey">
        <div style="font-size: 1rem; color: var(--text-muted);">Vilket datum är Doomsday i...</div>
        <div class="flashcard-date">@monthInfo!.MonthName</div>
        @if (monthIsLeapYear && (monthInfo.Month == 1 || monthInfo.Month == 2))
        {
            <div class="flashcard-hint">(skottår)</div>
        }
        else if (!monthIsLeapYear && (monthInfo.Month == 1 || monthInfo.Month == 2))
        {
            <div class="flashcard-hint">(vanligt år)</div>
        }

        @if (hasAnswered)
        {
            @if (wasCorrect)
            {
                <div class="success-box">✅ Rätt! Doomsday i @monthInfo.MonthName = den <strong>@monthCorrectDay:e</strong>.</div>
            }
            else
            {
                <div class="danger-box">❌ Fel. Du svarade @monthUserDay. Rätt: den <strong>@monthCorrectDay:e</strong>.</div>
            }
            <div class="tip-box" style="text-align: left;">@monthInfo.Mnemonic</div>
            <button class="btn btn-primary mt-2" @onclick="NextQuestion">Nästa →</button>
        }
        else
        {
            <div class="mt-3">
                <label class="form-label fw-semibold">Dag i månaden:</label>
                <div class="d-flex gap-2 align-items-center">
                    <input type="number" class="form-control" @bind="monthUserDay" min="1" max="31"
                           style="max-width: 100px;" @onkeydown="HandleMonthKeyDown" />
                    <button class="btn btn-primary" @onclick="AnswerMonth">Svara</button>
                </div>
            </div>
        }
    </div>
}

@code {
    private enum TrainingMode { None, CenturyAnchor, YearDoomsday, MonthDoomsday }

    private TrainingMode mode = TrainingMode.None;
    private int questionKey;
    private bool hasAnswered;
    private bool wasCorrect;
    private int answered;
    private int correct;
    private List<bool> streak = [];
    private static readonly Random _random = new();

    // Century
    private int centuryYear;
    private Weekday centuryCorrectAnswer;
    private Weekday centuryUserAnswer;

    // Year
    private int yearToGuess;
    private Weekday yearCenturyAnchor;
    private Weekday yearCorrectAnswer;
    private Weekday yearUserAnswer;

    // Month
    private MonthDoomsdayInfo? monthInfo;
    private bool monthIsLeapYear;
    private int monthCorrectDay;
    private int monthUserDay;

    private void SetMode(TrainingMode newMode)
    {
        mode = newMode;
        answered = 0;
        correct = 0;
        streak.Clear();
        NextQuestion();
    }

    private void NextQuestion()
    {
        hasAnswered = false;
        wasCorrect = false;
        questionKey++;

        switch (mode)
        {
            case TrainingMode.CenturyAnchor:
                var centuries = new[] { 1800, 1900, 2000, 2100 };
                centuryYear = centuries[_random.Next(centuries.Length)];
                centuryCorrectAnswer = CenturyAnchorCalculator.Calculate(centuryYear);
                break;

            case TrainingMode.YearDoomsday:
                yearToGuess = _random.Next(1800, 2100);
                yearCenturyAnchor = CenturyAnchorCalculator.Calculate(yearToGuess);
                yearCorrectAnswer = YearDoomsdayCalculator.Calculate(yearToGuess, yearCenturyAnchor);
                break;

            case TrainingMode.MonthDoomsday:
                var month = _random.Next(1, 13);
                monthInfo = MonthDoomsdayProvider.GetInfoForMonth(month);
                monthIsLeapYear = _random.Next(2) == 0;
                monthCorrectDay = MonthDoomsdayProvider.GetDoomsdayForMonth(month, monthIsLeapYear);
                monthUserDay = 0;
                break;
        }
    }

    private void RecordAnswer(bool isCorrect)
    {
        hasAnswered = true;
        wasCorrect = isCorrect;
        answered++;
        if (isCorrect) correct++;
        streak.Add(isCorrect);
    }

    private void AnswerCentury(Weekday answer)
    {
        centuryUserAnswer = answer;
        RecordAnswer(answer == centuryCorrectAnswer);
    }

    private void AnswerYear(Weekday answer)
    {
        yearUserAnswer = answer;
        RecordAnswer(answer == yearCorrectAnswer);
    }

    private void AnswerMonth()
    {
        RecordAnswer(monthUserDay == monthCorrectDay);
    }

    private void HandleMonthKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            AnswerMonth();
    }
}
