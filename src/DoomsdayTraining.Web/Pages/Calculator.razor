@page "/calculator"

<PageTitle>Kalkylator – Doomsday-Algoritmen</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">🔢 Doomsday-Kalkylator</MudText>
<MudText Typo="Typo.subtitle1" Class="mb-4">Ange valfritt datum och se hela beräkningen steg för steg med förklaringar.</MudText>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-3">📅 Välj datum</MudText>
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="3">
            <MudNumericField @bind-Value="year" Label="År" Min="1" Max="9999" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudSelect @bind-Value="month" Label="Månad" Variant="Variant.Outlined">
                @foreach (var monthInfo in MonthDoomsdayProvider.GetAll())
                {
                    <MudSelectItem Value="@monthInfo.Month">@monthInfo.Month – @monthInfo.MonthName</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="2">
            <MudNumericField @bind-Value="day" Label="Dag" Min="1" Max="31" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="3" Class="d-flex align-end gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="Calculate">Beräkna</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="SetToday">Idag</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="SetRandomDate">Slumpa</MudButton>
        </MudItem>
    </MudGrid>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Class="mt-3">@errorMessage</MudAlert>
    }
</MudPaper>

@if (result is not null)
{
    <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="mb-4" ContentAlignment="HorizontalAlignment.Center">
        <MudText Typo="Typo.h6">
            <strong>@result.Date.ToString("d MMMM yyyy", culture)</strong>
            är en <MudChip T="string" Color="Color.Surface" Size="Size.Small">@result.Weekday</MudChip>
        </MudText>
    </MudAlert>

    <MudText Typo="Typo.h5" Class="mb-3">Beräkningssteg</MudText>
    <MudTimeline TimelinePosition="TimelinePosition.Start">
        @foreach (var step in result.Steps)
        {
            <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                <ItemDot>
                    <MudAvatar Color="Color.Primary" Size="Size.Small">@step.StepNumber</MudAvatar>
                </ItemDot>
                <ItemContent>
                    <MudPaper Elevation="1" Class="pa-3 mb-2">
                        <MudText Typo="Typo.subtitle1"><strong>@step.Title</strong></MudText>
                        <MudText Typo="Typo.body2" Class="mt-1" Style="white-space: pre-line;">@step.Explanation</MudText>
                        <MudPaper Elevation="0" Class="pa-2 mt-2" Style="font-family: monospace; background: var(--mud-palette-background-gray, #f5f5f5); border-radius: 6px;">
                            @step.Calculation
                        </MudPaper>
                        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-1"><strong>Resultat: @step.Result</strong></MudText>
                    </MudPaper>
                </ItemContent>
            </MudTimelineItem>
        }
    </MudTimeline>

    <MudText Typo="Typo.h5" Class="mt-4 mb-3">Sammanfattning</MudText>
    <MudSimpleTable Elevation="2" Dense="true" Hover="true">
        <tbody>
            <tr><td>Datum</td><td><strong>@result.Date.ToString("yyyy-MM-dd")</strong></td></tr>
            <tr><td>Skottår</td><td>@(result.IsLeapYear ? "Ja ✓" : "Nej")</td></tr>
            <tr><td>Sekelankare</td><td><strong>@result.CenturyAnchor</strong></td></tr>
            <tr><td>Årets Doomsday</td><td><strong>@result.YearDoomsday</strong></td></tr>
            <tr><td>Doomsday-referens i månaden</td><td><strong>@result.MonthDoomsdayDate.ToString("d MMMM", culture)</strong></td></tr>
            <tr><td>Slutgiltig veckodag</td><td><MudChip T="string" Color="Color.Primary" Size="Size.Small">@result.Weekday</MudChip></td></tr>
        </tbody>
    </MudSimpleTable>
}

@code {
    private int year = 2024;
    private int month = 4;
    private int day = 10;
    private string? errorMessage;
    private DoomsdayResult? result;
    private readonly System.Globalization.CultureInfo culture = new("sv-SE");

    private void Calculate()
    {
        errorMessage = null;
        result = null;

        try
        {
            var daysInMonth = DateTime.DaysInMonth(year, month);
            if (day < 1 || day > daysInMonth)
            {
                errorMessage = $"Ogiltig dag: {month}/{day}. Månaden har {daysInMonth} dagar.";
                return;
            }
            var date = new DateOnly(year, month, day);
            result = DoomsdayAlgorithm.Calculate(date);
        }
        catch (Exception ex)
        {
            errorMessage = $"Ogiltigt datum: {ex.Message}";
        }
    }

    private void SetToday()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        year = today.Year;
        month = today.Month;
        day = today.Day;
        Calculate();
    }

    private void SetRandomDate()
    {
        var date = RandomDateGenerator.Generate();
        year = date.Year;
        month = date.Month;
        day = date.Day;
        Calculate();
    }
}
