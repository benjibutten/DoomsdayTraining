@page "/learn/month-doomsdays"

<PageTitle>Månadsdatum – Doomsday-Algoritmen</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">📋 Steg 3: Månadens Doomsday-datum</MudText>
<MudText Typo="Typo.subtitle1" Class="mb-4">Varje månad har datum som <strong>alltid</strong> infaller på årets Doomsday. Memorera dem!</MudText>

<MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
    <strong>Grundidé:</strong><br />
    Om du vet att 2024 har Doomsday = Torsdag, så vet du att 4 april, 6 juni, 8 augusti, 10 oktober
    och 12 december 2024 <em>alla</em> är torsdagar. Från dessa referenspunkter kan du räkna
    till valfritt datum i samma månad.
</MudAlert>

<MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-left: 4px solid var(--mud-palette-info); background: var(--mud-palette-background-gray, #f5f5f5);">
    <MudText Typo="Typo.subtitle1" Class="mb-2"><strong>🚩 Tänk på dem som landmärken längs en väg</strong></MudText>
    <MudText Typo="Typo.body1">
        Föreställ dig att varje månad är en vägsträcka, och Doomsday-datumet är ett
        <strong>landmärke</strong> du känner igen (en bensinstation, ett torg, en kyrka).
        När du vet exakt var landmärket ligger och vilken veckodag det är,
        kan du räkna steg därifrån till vilken adress som helst på vägen.
        Ju fler landmärken du memorerar, desto kortare avstånd behöver du räkna!
    </MudText>
</MudPaper>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">De tre grupperna</MudText>

<MudText Typo="Typo.h6" Class="mt-4 mb-2">🟢 Jämna månader (lättast!)</MudText>
<MudText Typo="Typo.body1" Class="mb-2">
    April, juni, augusti, oktober och december har alla Doomsday-datum som är
    <strong>samma som månadsnumret</strong>. Tänk på det som att månaden
    "tittar i spegeln" – den ser sig själv! April den 4:e, juni den 6:e, och så vidare.
</MudText>
<MudPaper Elevation="0" Class="pa-3 mb-2" Style="font-family:monospace; background:var(--mud-palette-background-gray,#f5f5f5); border-radius:6px; text-align:center; font-size:1.1rem;">
    4/4 &nbsp; 6/6 &nbsp; 8/8 &nbsp; 10/10 &nbsp; 12/12
</MudPaper>
<MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
    <strong>💡 Minnesregel:</strong> "Jämn månad = datum lika med månadsnumret." Enklare kan det inte bli!
</MudAlert>

<MudText Typo="Typo.h6" Class="mt-4 mb-2">🔵 Udda månader: "9-till-5 på 7-Eleven"</MudText>
<MudText Typo="Typo.body1" Class="mb-2">De udda månaderna (maj, juli, september, november) har ett fantastiskt minnestrick:</MudText>
<MudPaper Elevation="0" Class="pa-3 mb-2" Style="font-family:monospace; background:var(--mud-palette-background-gray,#f5f5f5); border-radius:6px; text-align:center; font-size:1.1rem;">
    5/9 &nbsp; 9/5 &nbsp; 7/11 &nbsp; 11/7
</MudPaper>
<MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
    <strong>💡 Minnesregel: "Jag jobbar 9 till 5 på 7-Eleven"</strong><br />
    • <strong>9-to-5:</strong> Maj den 9:e (5/9) och September den 5:e (9/5)<br />
    • <strong>7-Eleven:</strong> Juli den 11:e (7/11) och November den 7:e (11/7)<br />
    Notera mönstret: siffrorna byter plats mellan månad och dag!
</MudAlert>

<MudText Typo="Typo.h6" Class="mt-4 mb-2">🟡 Januari, februari och mars (specialfall)</MudText>

<MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-left: 4px solid var(--mud-palette-warning); background: var(--mud-palette-background-gray, #f5f5f5);">
    <MudText Typo="Typo.subtitle1" Class="mb-2"><strong>🌦️ Tänk på januari och februari som vinterns specialfall</strong></MudText>
    <MudText Typo="Typo.body1">
        Januari och februari är som den där gränden i stan som ändrar riktning beroende på vädret.
        Vid skottår får februari en extra dag, och det puttar referensdatumen ett steg.
        Tänk: "Normalt 3 januari och sista februari – men vid skottår får båda ett lyft på +1."
    </MudText>
</MudPaper>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-2">Januari &amp; Februari</MudText>
    <MudText Typo="Typo.body1" Class="mb-2">Dessa månader påverkas av <strong>skottår</strong>:</MudText>
    <MudSimpleTable Dense="true" Hover="true" Elevation="0">
        <thead>
            <tr><th>Månad</th><th>Normalt år</th><th>Skottår</th><th>Regel</th></tr>
        </thead>
        <tbody>
            <tr><td>Januari</td><td><strong>3 januari</strong></td><td><strong>4 januari</strong></td><td>Skottår = +1 dag</td></tr>
            <tr><td>Februari</td><td><strong>28 februari</strong></td><td><strong>29 februari</strong></td><td>Alltid sista dagen i februari</td></tr>
        </tbody>
    </MudSimpleTable>
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mt-2">
        <strong>💡 Minnesregel:</strong> "Den 3:e jan, den 28:e feb – och en extra vid skottår."
        Eller enklare: <strong>"Sista februari är alltid Doomsday"</strong>.
    </MudAlert>
</MudPaper>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-2">Mars</MudText>
    <MudText Typo="Typo.body1">
        Mars den <strong>7:e</strong> är Doomsday. Men det finns fler:
        <strong>14, 21 och 28 mars</strong> är alla Doomsdays (var 7:e dag).
    </MudText>
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mt-2">
        <strong>💡 Alternativt:</strong> "0 mars" = sista februari = också Doomsday!
        Allting i mars som är en multipel av 7 fungerar.
    </MudAlert>
</MudPaper>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">Alla datum i en tabell</MudText>
<MudSimpleTable Dense="true" Hover="true" Elevation="2">
    <thead>
        <tr><th>Månad</th><th>Doomsday-datum</th><th>Minnesregel</th></tr>
    </thead>
    <tbody>
        @foreach (var month in MonthDoomsdayProvider.GetAll())
        {
            <tr>
                <td><strong>@month.MonthName</strong></td>
                <td>
                    @month.Day:e
                    @if (month.LeapYearDay.HasValue)
                    {
                        <MudText Typo="Typo.caption" Inline="true"> (skottår: @(month.LeapYearDay):e)</MudText>
                    }
                </td>
                <td>@month.Mnemonic</td>
            </tr>
        }
    </tbody>
</MudSimpleTable>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">🗓️ Alla Doomsday-datum per månad</MudText>
<MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-left: 4px solid var(--mud-palette-info); background: var(--mud-palette-background-gray, #f5f5f5);">
    <MudText Typo="Typo.body1" Class="mb-2">
        Varje månad har <strong>4–5 datum</strong> som alla är Doomsday. Ju fler du memorerar, desto kortare
        avstånd behöver du räkna! Tabellen nedan visar alla Doomsday-datum i varje månad.
    </MudText>
    <MudText Typo="Typo.body2">
        💡 <strong>Tips:</strong> Läs igenom listan och <em>säg dem högt</em> — "3, 10, 17, 24, 31 januari" osv.
        Gå sedan till <MudLink Href="practice/month-doomsday-drill">Månadsdrillningen</MudLink> och testa dig själv!
    </MudText>
</MudPaper>

<MudSimpleTable Dense="true" Hover="true" Elevation="2" Class="mb-4">
    <thead>
        <tr><th>Månad</th><th>Alla Doomsday-datum</th><th>Antal</th></tr>
    </thead>
    <tbody>
        @foreach (var month in MonthDoomsdayProvider.GetAll())
        {
            var allDates = MonthDoomsdayProvider.GetValidDoomsdayDatesForMonth(month.Month, false);
            <tr>
                <td><strong>@month.MonthName</strong></td>
                <td>@string.Join(", ", allDates.Select(d => $"{d}:e"))</td>
                <td>@allDates.Count</td>
            </tr>
        }
    </tbody>
</MudSimpleTable>
<MudExpansionPanels Class="mb-4" Elevation="2">
    <MudExpansionPanel Text="Visa även för skottår (januari & februari)" MaxHeight="300">
        <MudSimpleTable Dense="true" Hover="true" Elevation="0">
            <thead><tr><th>Månad</th><th>Alla Doomsday-datum (skottår)</th></tr></thead>
            <tbody>
                <tr>
                    <td><strong>Januari (skottår)</strong></td>
                    <td>@string.Join(", ", MonthDoomsdayProvider.GetValidDoomsdayDatesForMonth(1, true).Select(d => $"{d}:e"))</td>
                </tr>
                <tr>
                    <td><strong>Februari (skottår)</strong></td>
                    <td>@string.Join(", ", MonthDoomsdayProvider.GetValidDoomsdayDatesForMonth(2, true).Select(d => $"{d}:e"))</td>
                </tr>
            </tbody>
        </MudSimpleTable>
    </MudExpansionPanel>
</MudExpansionPanels>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">Snabbtest: Kan du dem?</MudText>
<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-3">🧪 Vilket datum är Doomsday i...?</MudText>
    <MudText Typo="Typo.body2" Class="mb-3">Testa utan att titta på tabellen — byt månad och svara!</MudText>
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="4">
            <MudSelect @bind-Value="selectedMonth" Label="Välj månad" Variant="Variant.Outlined">
                @foreach (var monthInfo in MonthDoomsdayProvider.GetAll())
                {
                    <MudSelectItem Value="@monthInfo.Month">@monthInfo.MonthName</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudSelect @bind-Value="isLeapYear" Label="Skottår?" Variant="Variant.Outlined">
                <MudSelectItem Value="false">Nej (vanligt år)</MudSelectItem>
                <MudSelectItem Value="true">Ja (skottår)</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="3" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ShowAnswer">Visa svar</MudButton>
        </MudItem>
    </MudGrid>

    @if (showAnswer)
    {
        var info = MonthDoomsdayProvider.GetInfoForMonth(selectedMonth);
        var day = MonthDoomsdayProvider.GetDoomsdayForMonth(selectedMonth, isLeapYear);
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mt-3">
            <strong>@info.MonthName:</strong> Doomsday-datum är den <strong>@day:e</strong><br />
            <MudText Typo="Typo.caption">@info.Mnemonic</MudText>
        </MudAlert>
    }
</MudPaper>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">Från referensdatum till måldatum</MudText>
<MudText Typo="Typo.body1" Class="mb-3">
    Att kunna referensdalen räcker inte – du måste också kunna hoppa från den till vilket datum som helst i månaden.
    Prova tankekedjan nedan. <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="NewDemoDate">Nytt exempel →</MudButton>
</MudText>

<MudPaper Elevation="2" Class="pa-4 mb-4" @key="demoKey">
    @{
        var demoRef = MonthDoomsdayProvider.GetDoomsdayForMonth(demoDate.Month, LeapYearChecker.IsLeapYear(demoDate.Year));
        var demoDiff = demoDate.Day - demoRef;
        var demoDiffMod = ((demoDiff % 7) + 7) % 7;
        var demoMInfo = MonthDoomsdayProvider.GetInfoForMonth(demoDate.Month);
        var demoWeekday = DoomsdayAlgorithm.GetWeekday(demoDate);
        var demoYearDoomsday = YearDoomsdayCalculator.Calculate(demoDate.Year);
        var svCulture = new System.Globalization.CultureInfo("sv-SE");
    }
    <MudText Typo="Typo.h6" Class="mb-1">📝 @demoDate.ToString("d MMMM yyyy", svCulture)</MudText>
    <MudText Typo="Typo.body2" Class="mb-3">Anta att vi redan vet att årets Doomsday är <strong>@demoYearDoomsday</strong>.</MudText>
    <MudSimpleTable Dense="true" Hover="true" Elevation="0">
        <thead><tr><th>Tanken</th><th>Beräkning</th><th>Resultat</th></tr></thead>
        <tbody>
            <tr><td>Doomsday-referens i månaden</td><td>@demoMInfo.MonthName → @demoMInfo.Mnemonic</td><td><strong>@demoRef/@demoDate.Month = @demoYearDoomsday</strong></td></tr>
            <tr><td>Avstånd till @demoDate.Day:e</td><td>@demoDate.Day − @demoRef = @demoDiff dagar</td><td><strong>@demoDiff dagar @(demoDiff >= 0 ? "framåt" : "bakåt")</strong></td></tr>
            <tr><td>Förenkla (mod 7)</td><td>|@demoDiff| mod 7 = @demoDiffMod</td><td><strong>@demoDiffMod dag(ar) @(demoDiff >= 0 ? "framåt" : "bakåt")</strong></td></tr>
            <tr><td>Räkna från Doomsday</td><td>@demoYearDoomsday + @(demoDiff >= 0 ? "+" : "")@demoDiff (mod 7)</td><td><strong>@demoWeekday</strong></td></tr>
        </tbody>
    </MudSimpleTable>
    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mt-3">
        @demoDate.ToString("d MMMM yyyy", svCulture) är en <strong>@demoWeekday</strong>.
    </MudAlert>
</MudPaper>

<div class="d-flex gap-2 mt-4">
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="learn/year-doomsday" StartIcon="@Icons.Material.Filled.ArrowBack">Steg 2: Årets Doomsday</MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="learn/final-step" EndIcon="@Icons.Material.Filled.ArrowForward">Steg 4: Sista steget</MudButton>
</div>

@code {
    private int _selectedMonth = 1;
    private int selectedMonth
    {
        get => _selectedMonth;
        set { _selectedMonth = value; showAnswer = false; }
    }

    private bool _isLeapYear;
    private bool isLeapYear
    {
        get => _isLeapYear;
        set { _isLeapYear = value; showAnswer = false; }
    }

    private bool showAnswer;

    private void ShowAnswer() => showAnswer = true;

    // Demo: "från referensdatum till måldatum"
    private static readonly DateOnly[] DemoDates =
    [
        new DateOnly(2024, 4, 17),
        new DateOnly(2024, 6, 23),
        new DateOnly(2024, 9, 2),
        new DateOnly(2024, 11, 19),
        new DateOnly(2024, 7, 30),
        new DateOnly(2024, 8, 5),
        new DateOnly(2024, 12, 27),
        new DateOnly(2024, 5, 13),
        new DateOnly(2024, 3, 22),
        new DateOnly(2024, 10, 31),
    ];

    private DateOnly demoDate;
    private int demoKey;

    protected override void OnInitialized()
    {
        demoDate = DemoDates[Random.Shared.Next(DemoDates.Length)];
        _selectedMonth = Random.Shared.Next(1, 13);
    }

    private void NewDemoDate()
    {
        DateOnly next;
        do { next = DemoDates[Random.Shared.Next(DemoDates.Length)]; }
        while (next == demoDate);
        demoDate = next;
        demoKey++;
    }
}
