@page "/learn/final-step"

<PageTitle>Sista steget – Doomsday-Algoritmen</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">🎯 Steg 4: Räkna fram till måldatumet</MudText>
<MudText Typo="Typo.subtitle1" Class="mb-4">Det sista och enklaste steget – räkna dagar från Doomsday-referensen till ditt datum.</MudText>

<MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
    <strong>Nu har du alla pusselbitar!</strong><br />
    Du vet årets Doomsday-veckodag (från steg 1+2) och du vet Doomsday-referensdatumet
    i den aktuella månaden (från steg 3). Nu räknar du bara avståndet i dagar.
</MudAlert>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">Så här gör du</MudText>

<MudTimeline TimelinePosition="TimelinePosition.Start" Class="mb-4">
    <MudTimelineItem Color="Color.Primary" Size="Size.Small">
        <ItemDot><MudAvatar Color="Color.Primary" Size="Size.Small">1</MudAvatar></ItemDot>
        <ItemContent>
            <MudPaper Elevation="1" Class="pa-3 mb-2">
                <MudText Typo="Typo.subtitle1"><strong>Hitta skillnaden i dagar</strong></MudText>
                <MudText Typo="Typo.body2" Style="white-space:pre-line;">Räkna hur många dagar det är mellan Doomsday-referensdatumet och ditt måldatum.

Exempel: Doomsday i april = den 4:e. Ditt datum = 19 april.
Skillnad: 19 − 4 = 15 dagar framåt.</MudText>
            </MudPaper>
        </ItemContent>
    </MudTimelineItem>
    <MudTimelineItem Color="Color.Primary" Size="Size.Small">
        <ItemDot><MudAvatar Color="Color.Primary" Size="Size.Small">2</MudAvatar></ItemDot>
        <ItemContent>
            <MudPaper Elevation="1" Class="pa-3 mb-2">
                <MudText Typo="Typo.subtitle1"><strong>Förenkla med mod 7</strong></MudText>
                <MudText Typo="Typo.body2" Style="white-space:pre-line;">Eftersom en vecka har 7 dagar bryr vi oss bara om resten vid division med 7.

Exempel: 15 mod 7 = 1 dag framåt.
(15 dagar = 2 hela veckor + 1 dag)</MudText>
            </MudPaper>
        </ItemContent>
    </MudTimelineItem>
    <MudTimelineItem Color="Color.Primary" Size="Size.Small">
        <ItemDot><MudAvatar Color="Color.Primary" Size="Size.Small">3</MudAvatar></ItemDot>
        <ItemContent>
            <MudPaper Elevation="1" Class="pa-3 mb-2">
                <MudText Typo="Typo.subtitle1"><strong>Räkna fram (eller bak) från Doomsday</strong></MudText>
                <MudText Typo="Typo.body2" Style="white-space:pre-line;">Lägg till (eller dra ifrån) dagarna till årets Doomsday-veckodag.

Exempel: Om Doomsday = Torsdag och vi ska framåt 1 dag:
Torsdag + 1 = Fredag ✓</MudText>
            </MudPaper>
        </ItemContent>
    </MudTimelineItem>
</MudTimeline>

<MudPaper Elevation="0" Class="pa-3 mb-4" Style="font-family:monospace; background:var(--mud-palette-background-gray,#f5f5f5); border-radius:6px; text-align:center;">
    Veckodag = (Doomsday-veckodag + skillnad) mod 7
</MudPaper>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">Genomgångsexempel</MudText>
<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-3">📝 Exempel: 19 april 2024</MudText>
    <MudSimpleTable Dense="true" Hover="true" Elevation="0">
        <thead>
            <tr><th>Steg</th><th>Info</th><th>Resultat</th></tr>
        </thead>
        <tbody>
            <tr><td>Årets Doomsday (2024)</td><td>Från steg 1+2</td><td><strong>Torsdag</strong></td></tr>
            <tr><td>Doomsday-datum i april</td><td>4/4 (jämn månad)</td><td><strong>4 april = Torsdag</strong></td></tr>
            <tr><td>Skillnad till 19:e</td><td>19 − 4 = 15 dagar</td><td><strong>15 dagar</strong></td></tr>
            <tr><td>Mod 7</td><td>15 mod 7 = 1</td><td><strong>1 dag framåt</strong></td></tr>
            <tr><td>Slutresultat</td><td>Torsdag + 1 dag</td><td><strong>Fredag ✓</strong></td></tr>
        </tbody>
    </MudSimpleTable>
</MudPaper>

<MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
    <strong>💡 Tips: Räkna åt båda hållen!</strong><br />
    Om ditt datum ligger nära slutet av månaden, kan det vara lättare att räkna <em>bakåt</em>
    från nästa månads Doomsday. Till exempel:
    för 2 april kan du räkna 4 − 2 = 2 dagar bakåt från Doomsday istället.
</MudAlert>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">Testa hela algoritmen</MudText>
<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-3">🧪 Prova med ett datum</MudText>
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="4">
            <MudDatePicker @bind-Date="testDateTime" Label="Datum" Variant="Variant.Outlined" DateFormat="yyyy-MM-dd" />
        </MudItem>
        <MudItem xs="12" sm="3" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ShowResult">Beräkna</MudButton>
        </MudItem>
    </MudGrid>

    @if (result is not null)
    {
        <MudTimeline TimelinePosition="TimelinePosition.Start" Class="mt-3">
            @foreach (var step in result.Steps)
            {
                <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                    <ItemDot><MudAvatar Color="Color.Primary" Size="Size.Small">@step.StepNumber</MudAvatar></ItemDot>
                    <ItemContent>
                        <MudPaper Elevation="1" Class="pa-3 mb-2">
                            <MudText Typo="Typo.subtitle1"><strong>@step.Title</strong></MudText>
                            <MudText Typo="Typo.body2" Style="white-space:pre-line;">@step.Explanation</MudText>
                            <MudPaper Elevation="0" Class="pa-2 mt-2" Style="font-family:monospace; background:var(--mud-palette-background-gray,#f5f5f5); border-radius:6px;">@step.Calculation</MudPaper>
                            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-1"><strong>Resultat: @step.Result</strong></MudText>
                        </MudPaper>
                    </ItemContent>
                </MudTimelineItem>
            }
        </MudTimeline>
        <MudAlert Severity="Severity.Success" Variant="Variant.Filled" ContentAlignment="HorizontalAlignment.Center" Class="mt-3">
            <MudText Typo="Typo.h6">
                <strong>@result.Date.ToString("d MMMM yyyy", new System.Globalization.CultureInfo("sv-SE"))</strong>
                är en <MudChip T="string" Color="Color.Surface" Size="Size.Small">@result.Weekday</MudChip>
            </MudText>
        </MudAlert>
    }
</MudPaper>

<div class="d-flex gap-2 mt-4">
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="learn/month-doomsdays" StartIcon="@Icons.Material.Filled.ArrowBack">Steg 3: Månadsdatum</MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="learn/shortcuts" EndIcon="@Icons.Material.Filled.ArrowForward">Genvägar & tips</MudButton>
</div>

@code {
    private DateTime? testDateTime = new DateTime(2024, 4, 19);
    private DoomsdayResult? result;

    private void ShowResult()
    {
        if (testDateTime.HasValue)
        {
            var testDate = DateOnly.FromDateTime(testDateTime.Value);
            result = DoomsdayAlgorithm.Calculate(testDate);
        }
    }
}
