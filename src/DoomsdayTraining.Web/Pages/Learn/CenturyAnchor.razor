@page "/learn/century-anchor"

<PageTitle>Sekelankaret – Doomsday-Algoritmen</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">🏛️ Steg 1: Sekelankaret</MudText>
<MudText Typo="Typo.subtitle1" Class="mb-4">Varje sekel har en fast "ankardag" – en veckodag som utgör startpunkten för alla beräkningar.</MudText>

<MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
    <strong>Vad är sekelankaret?</strong><br />
    Om du tar ett "jämnt sekelår" (som 1900 eller 2000) och räknar ut veckodagen för till exempel
    4 april, 6 juni etc. – det blir sekelankaret. Det är startpunkten som vi sedan justerar för
    varje specifikt år.
</MudAlert>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">De fyra sekelankarna</MudText>
<MudText Typo="Typo.body1" Class="mb-3">Det finns bara fyra att lära sig. De upprepas i en cykel var 400:e år.</MudText>

<MudGrid Spacing="3" Class="mb-4">
    @foreach (var anchor in CenturyAnchorCalculator.GetAllAnchorsInCycle())
    {
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center">
                <MudText Typo="Typo.caption">@(anchor.CenturyStart)-talet</MudText>
                <MudText Typo="Typo.h5" Color="Color.Secondary" Class="mt-1"><strong>@anchor.AnchorDay</strong></MudText>
            </MudPaper>
        </MudItem>
    }
</MudGrid>

<MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
    <strong>🧠 Minnesregel: "FrOTS"</strong><br />
    <strong>Fr</strong>edag → <strong>O</strong>nsdag → <strong>T</strong>isdag → <strong>S</strong>öndag<br />
    1800 → 1900 → 2000 → 2100<br />
    Säg det högt några gånger: "Frots, Frots, Frots" – och du har dem!
</MudAlert>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">Formeln bakom (för den nyfikne)</MudText>
<MudText Typo="Typo.body1" Class="mb-2">
    Du behöver inte formeln för att använda algoritmen – det räcker att memorera de fyra dagarna.
    Men om du vill förstå matematiken:
</MudText>
<MudPaper Elevation="0" Class="pa-3 mb-2" Style="font-family:monospace; background:var(--mud-palette-background-gray,#f5f5f5); border-radius:6px; text-align:center;">
    ankardag = (5 × (sekeltal mod 4) + 2) mod 7
</MudPaper>
<MudText Typo="Typo.body2" Class="mb-4">Där "sekeltal" är de första två siffrorna i årtalet (t.ex. 20 för 2000-talet).</MudText>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">Testa själv</MudText>
<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-2">🧪 Prova med ett år</MudText>
    <MudText Typo="Typo.body2" Class="mb-3">Skriv in ett årtal så visar vi vilket sekelankare det tillhör och hur beräkningen ser ut:</MudText>
    <MudNumericField @bind-Value="testYear" Label="Årtal" Min="1" Max="9999" Variant="Variant.Outlined" Style="max-width:200px;" Immediate="true" />

    @if (testYear > 0)
    {
        var info = CenturyAnchorCalculator.GetInfo(testYear);
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mt-3">
            <strong>Resultat:</strong> @info.CenturyStart-talet har ankardagen
            <MudChip T="string" Color="Color.Primary" Size="Size.Small">@info.AnchorDay</MudChip><br />
            <MudText Typo="Typo.caption">@info.Explanation</MudText>
        </MudAlert>
    }
</MudPaper>

<div class="d-flex gap-2 mt-4">
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="learn/overview" StartIcon="@Icons.Material.Filled.ArrowBack">Tillbaka till översikten</MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="learn/year-doomsday" EndIcon="@Icons.Material.Filled.ArrowForward">Steg 2: Årets Doomsday</MudButton>
</div>

@code {
    private int testYear = 2024;
}
