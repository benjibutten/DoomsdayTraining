@page "/learn/century-anchor"

<PageTitle>Sekelankaret – Doomsday-Algoritmen</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">🏛️ Steg 1: Sekelankaret</MudText>
<MudText Typo="Typo.subtitle1" Class="mb-4">Varje sekel har en fast "ankardag" – en veckodag som utgör startpunkten för alla beräkningar.</MudText>

<MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
    <strong>Vad är sekelankaret?</strong><br />
    Om du tar ett "jämnt sekelår" (som 1900 eller 2000) och räknar ut veckodagen för till exempel
    4 april, 6 juni etc. – det blir sekelankaret. Det är startpunkten som vi sedan justerar för
    varje specifikt år.
</MudAlert>

<MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-left: 4px solid var(--mud-palette-info); background: var(--mud-palette-background-gray, #f5f5f5);">
    <MudText Typo="Typo.subtitle1" Class="mb-2"><strong>⏰ Tänk på det som tidszoner</strong></MudText>
    <MudText Typo="Typo.body1">
        Precis som varje tidszon har en fast förskjutning från UTC (New York = −5, Stockholm = +1),
        har varje sekel en fast förskjutning från en "nollpunkt". Du behöver inte beräkna tidszonen
        varje gång – du memorerar den bara. På samma sätt memorerar du sekelankaret.
        När du hör "1900-talet" tänker du direkt <strong>Onsdag</strong>, precis som du direkt vet
        att Stockholm är +1.
    </MudText>
</MudPaper>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">De fyra sekelankarna</MudText>
<MudText Typo="Typo.body1" Class="mb-3">Det finns bara fyra att lära sig. De upprepas i en cykel var 400:e år.</MudText>

<MudGrid Spacing="3" Class="mb-4">
    @foreach (var anchor in CenturyAnchorCalculator.GetAllAnchorsInCycle())
    {
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center">
                <MudText Typo="Typo.caption">@(anchor.CenturyStart)-talet</MudText>
                <MudText Typo="Typo.h5" Color="Color.Secondary" Class="mt-1"><strong>@anchor.AnchorDay</strong></MudText>
            </MudPaper>
        </MudItem>
    }
</MudGrid>

<MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
    <strong>🧠 Minnesregel: "FrOTS"</strong><br />
    <strong>Fr</strong>edag (1800) → <strong>O</strong>nsdag (1900) → <strong>T</strong>isdag (2000) → <strong>S</strong>öndag (2100)<br />
    Säg det högt några gånger: "Frots, Frots, Frots" – och du har alla fyra!
</MudAlert>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">Varför just dessa dagar?</MudText>
<MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-left: 4px solid var(--mud-palette-warning); background: var(--mud-palette-background-gray, #f5f5f5);">
    <MudText Typo="Typo.subtitle1" Class="mb-2"><strong>🔄 Tänk på det som ett kugghjul</strong></MudText>
    <MudText Typo="Typo.body1" Class="mb-2">
        Föreställ dig att kalendern är ett kugghjul med 7 kuggar (en för varje veckodag).
        För varje sekel som passerar vrids kugghjulet lite – men inte jämnt.
        Det vrids <strong>5 kuggar bakåt</strong> (eller 2 framåt, samma sak) för varje sekel.
        NiFrOTS är helt enkelt positionerna där kugghjulet hamnar vid varje sekelskifte.
    </MudText>
</MudPaper>
<MudPaper Elevation="1" Class="pa-4 mb-4">
    <MudText Typo="Typo.body1" Class="mb-2">
        Varje sekel om 100 år innehåller 36 524 dagar (vanliga år) eller 36 525 (om seklet råkar ha ett extra skottår).
        Enligt den gregorianska kalenderregeln är sekelår <em>inte</em> skottår såvida de inte är delbara med 400.
        Det gör att 100 år = 52 veckor × 7 dagar × 100 + lite extra = ett antal hela veckor plus en rest.
    </MudText>
    <MudText Typo="Typo.body1">
        Den resten är precis <strong>5 dagar bakåt</strong> (eller 2 framåt, det är samma sak mod 7) för varje sekel.
        Så om 1900-talet börjar på Onsdag (3) börjar 2000-talet på Tisdag (2 = 3 − 1 mod 7).
        Det är just det mönstret som FrOTS sammanfattar.
    </MudText>
</MudPaper>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">Testa dig – välj rätt ankardag</MudText>
<MudPaper Elevation="2" Class="pa-4 mb-4" @key="quizKey">
    <MudText Typo="Typo.body2" Class="mb-1">Vilket sekelankare har...</MudText>
    <MudText Typo="Typo.h3" Color="Color.Primary" Align="Align.Center" Class="mb-4">@quizCentury-talet</MudText>

    @if (!quizAnswered)
    {
        <MudGrid Spacing="2" Justify="Justify.Center">
            @foreach (Weekday day in Enum.GetValues<Weekday>())
            {
                var d = day;
                <MudItem xs="4" sm="3">
                    <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Primary" OnClick="() => AnswerQuiz(d)" Size="Size.Small">@d</MudButton>
                </MudItem>
            }
        </MudGrid>
    }
    else
    {
        <MudGrid Spacing="2" Justify="Justify.Center" Class="mb-3">
            @foreach (Weekday day in Enum.GetValues<Weekday>())
            {
                var color = day == quizCorrectAnswer ? Color.Success
                          : (day == quizUserAnswer && !quizWasCorrect) ? Color.Error
                          : Color.Default;
                var variant = (day == quizCorrectAnswer || (day == quizUserAnswer && !quizWasCorrect)) ? Variant.Filled : Variant.Outlined;
                <MudItem xs="4" sm="3">
                    <MudButton FullWidth="true" Variant="@variant" Color="@color" Disabled="true" Size="Size.Small">@day</MudButton>
                </MudItem>
            }
        </MudGrid>
        @if (quizWasCorrect)
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-3">✅ Rätt! @quizCentury-talet = <strong>@quizCorrectAnswer</strong>.</MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-3">❌ Fel. Du svarade @quizUserAnswer. Rätt: <strong>@quizCorrectAnswer</strong>.</MudAlert>
        }
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-3">
            Kom ihåg: <strong>FrOTS</strong> – Fredag (1800) → Onsdag (1900) → Tisdag (2000) → Söndag (2100)
        </MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="NextQuiz" EndIcon="@Icons.Material.Filled.ArrowForward">Nästa fråga</MudButton>
    }
</MudPaper>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">Formeln bakom (för den nyfikne)</MudText>
<MudText Typo="Typo.body1" Class="mb-2">
    Minnesregeln räcker för att använda algoritmen. Men om du vill förstå matematiken:
</MudText>
<MudPaper Elevation="0" Class="pa-3 mb-2" Style="font-family:monospace; background:var(--mud-palette-background-gray,#f5f5f5); border-radius:6px; text-align:center;">
    ankardag = (5 × (sekeltal mod 4) + 2) mod 7
</MudPaper>
<MudText Typo="Typo.body2" Class="mb-4">Där "sekeltal" är de första två siffrorna i årtalet (t.ex. 20 för 2000-talet).</MudText>

<MudText Typo="Typo.h5" Class="mt-4 mb-3">Slå upp vilket år som helst</MudText>
<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.body2" Class="mb-3">Skriv in ett godtyckligt år och se vilket sekelankare det tillhör:</MudText>
    <MudNumericField @bind-Value="testYear" Label="Årtal" Min="1" Max="9999" Variant="Variant.Outlined" Style="max-width:200px;" Immediate="true" />

    @if (testYear > 0)
    {
        var info = CenturyAnchorCalculator.GetInfo(testYear);
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mt-3">
            <strong>Resultat:</strong> @info.CenturyStart-talet har ankardagen
            <MudChip T="string" Color="Color.Primary" Size="Size.Small">@info.AnchorDay</MudChip><br />
            <MudText Typo="Typo.caption">@info.Explanation</MudText>
        </MudAlert>
    }
</MudPaper>

<div class="d-flex gap-2 mt-4">
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="learn/overview" StartIcon="@Icons.Material.Filled.ArrowBack">Tillbaka till översikten</MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="learn/year-doomsday" EndIcon="@Icons.Material.Filled.ArrowForward">Steg 2: Årets Doomsday</MudButton>
</div>

@code {
    private int testYear = 2024;

    // Quiz
    private static readonly int[] QuizCenturies = [1800, 1900, 2000, 2100];
    private int quizKey;
    private int quizCentury;
    private Weekday quizCorrectAnswer;
    private Weekday quizUserAnswer;
    private bool quizAnswered;
    private bool quizWasCorrect;

    protected override void OnInitialized() => NewQuizCentury();

    private void NewQuizCentury()
    {
        quizCentury = QuizCenturies[Random.Shared.Next(QuizCenturies.Length)];
        quizCorrectAnswer = CenturyAnchorCalculator.Calculate(quizCentury);
        quizAnswered = false;
        quizKey++;
    }

    private void AnswerQuiz(Weekday answer)
    {
        quizUserAnswer = answer;
        quizWasCorrect = answer == quizCorrectAnswer;
        quizAnswered = true;
    }

    private void NextQuiz() => NewQuizCentury();
}
