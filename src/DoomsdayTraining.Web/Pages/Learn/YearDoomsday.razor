@page "/learn/year-doomsday"

<PageTitle>Årets Doomsday – Doomsday-Algoritmen</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">📅 Steg 2: Beräkna årets Doomsday</MudText>
<MudText Typo="Typo.subtitle1" Class="mb-4">Justera sekelankaret för att hitta veckodagen som alla Doomsday-datum faller på i ett specifikt år.</MudText>

<MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
    <strong>Målet med detta steg:</strong><br />
    Vi vet nu sekelankaret (t.ex. Tisdag för 2000-talet). Men varje år inom seklet har sin
    <em>egen</em> Doomsday. Vi behöver anpassa sekelankaret med hjälp av de sista två siffrorna i årtalet.
</MudAlert>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">"12-metoden" (Conway's metod)</MudText>
<MudText Typo="Typo.body1" Class="mb-3">Den populäraste metoden för att snabbt räkna i huvudet. Fyra steg:</MudText>

<MudTimeline TimelinePosition="TimelinePosition.Start" Class="mb-4">
    <MudTimelineItem Color="Color.Primary" Size="Size.Small">
        <ItemDot><MudAvatar Color="Color.Primary" Size="Size.Small">a</MudAvatar></ItemDot>
        <ItemContent>
            <MudPaper Elevation="1" Class="pa-3 mb-2">
                <MudText Typo="Typo.subtitle1"><strong>Ta de sista två siffrorna</strong></MudText>
                <MudText Typo="Typo.body2">Kalla dem <strong>y</strong>. Till exempel: 2024 → y = 24, 1987 → y = 87.</MudText>
            </MudPaper>
        </ItemContent>
    </MudTimelineItem>
    <MudTimelineItem Color="Color.Primary" Size="Size.Small">
        <ItemDot><MudAvatar Color="Color.Primary" Size="Size.Small">b</MudAvatar></ItemDot>
        <ItemContent>
            <MudPaper Elevation="1" Class="pa-3 mb-2">
                <MudText Typo="Typo.subtitle1"><strong>Dela y med 12</strong></MudText>
                <MudText Typo="Typo.body2" Style="white-space:pre-line;">Beräkna kvoten och resten:
• y ÷ 12 = kvot (heltalsdivision)
• y mod 12 = rest (det som blir över)

Exempel: 87 ÷ 12 = 7 rest 3</MudText>
            </MudPaper>
        </ItemContent>
    </MudTimelineItem>
    <MudTimelineItem Color="Color.Primary" Size="Size.Small">
        <ItemDot><MudAvatar Color="Color.Primary" Size="Size.Small">c</MudAvatar></ItemDot>
        <ItemContent>
            <MudPaper Elevation="1" Class="pa-3 mb-2">
                <MudText Typo="Typo.subtitle1"><strong>Dela resten med 4</strong></MudText>
                <MudText Typo="Typo.body2" Style="white-space:pre-line;">Ta resten från föregående steg och dela med 4 (heltalsdivision):
• rest ÷ 4 = skottårsjustering

Exempel: 3 ÷ 4 = 0 (tre innehåller inga hela 4:or)</MudText>
            </MudPaper>
        </ItemContent>
    </MudTimelineItem>
    <MudTimelineItem Color="Color.Primary" Size="Size.Small">
        <ItemDot><MudAvatar Color="Color.Primary" Size="Size.Small">d</MudAvatar></ItemDot>
        <ItemContent>
            <MudPaper Elevation="1" Class="pa-3 mb-2">
                <MudText Typo="Typo.subtitle1"><strong>Summera och ta mod 7</strong></MudText>
                <MudText Typo="Typo.body2">Lägg ihop sekelankaret + kvot + rest + skottårsjustering.
Ta sedan mod 7 (resten vid division med 7) för att få veckodagen.</MudText>
            </MudPaper>
        </ItemContent>
    </MudTimelineItem>
</MudTimeline>

<MudPaper Elevation="0" Class="pa-3 mb-4" Style="font-family:monospace; background:var(--mud-palette-background-gray,#f5f5f5); border-radius:6px; text-align:center;">
    Doomsday = (sekelankare + kvot + rest + skottårsjustering) mod 7
</MudPaper>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">Genomgångsexempel</MudText>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-3">📝 Exempel: År 1987</MudText>
    <MudSimpleTable Dense="true" Hover="true" Elevation="0">
        <thead>
            <tr><th>Delsteg</th><th>Beräkning</th><th>Resultat</th></tr>
        </thead>
        <tbody>
            <tr><td>Sekelankare (1900-talet)</td><td>Memorerat</td><td><strong>Onsdag (3)</strong></td></tr>
            <tr><td>y = sista två siffrorna</td><td>1987 → 87</td><td><strong>87</strong></td></tr>
            <tr><td>87 ÷ 12</td><td>87 = 7 × 12 + 3</td><td>Kvot: <strong>7</strong>, Rest: <strong>3</strong></td></tr>
            <tr><td>Rest ÷ 4</td><td>3 ÷ 4 = 0</td><td>Justering: <strong>0</strong></td></tr>
            <tr><td>Summa</td><td>3 + 7 + 3 + 0 = 13</td><td><strong>13</strong></td></tr>
            <tr><td>Mod 7</td><td>13 mod 7 = 6</td><td><strong>Lördag (6)</strong></td></tr>
        </tbody>
    </MudSimpleTable>
    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mt-3">
        Alla Doomsday-datum 1987 (4/4, 6/6, 8/8 osv.) infaller på en <strong>Lördag</strong>.
    </MudAlert>
</MudPaper>

<MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4">
    <strong>💡 Varför funkar 12-metoden?</strong><br />
    Ett vanligt år har <strong>365 dagar</strong>, vilket är 52 veckor + 1 dag.
    Alltså skiftar veckodagen 1 dag per år. Men vart 4:e år är det skottår (en extra dag).
    12 år = 12 + 3 skottår = 15 extra dagar = 2 veckor + 1 dag = exakt 1 veckodagsshift.
    Därför delar vi med 12!
</MudAlert>

<MudText Typo="Typo.h5" Class="mt-6 mb-3">Testa själv</MudText>
<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudText Typo="Typo.h6" Class="mb-2">🧪 Beräkna årets Doomsday</MudText>
    <MudNumericField @bind-Value="testYear" Label="Årtal" Min="1" Max="9999" Variant="Variant.Outlined" Style="max-width:200px;" Immediate="true" />

    @if (testYear > 0)
    {
        var centuryAnchor = CenturyAnchorCalculator.Calculate(testYear);
        var (quotient, remainder, leapAdj, doomsday) =
            YearDoomsdayCalculator.GetComponents(testYear, centuryAnchor);
        var y = testYear % 100;

        <MudSimpleTable Dense="true" Hover="true" Elevation="0" Class="mt-3">
            <thead>
                <tr><th>Delsteg</th><th>Beräkning</th><th>Resultat</th></tr>
            </thead>
            <tbody>
                <tr><td>Sekelankare</td><td>@(testYear / 100 * 100)-talet</td><td><strong>@centuryAnchor (@((int)centuryAnchor))</strong></td></tr>
                <tr><td>y</td><td>@testYear → @y</td><td><strong>@y</strong></td></tr>
                <tr><td>y ÷ 12</td><td>@y ÷ 12 = @quotient rest @remainder</td><td>Kvot: <strong>@quotient</strong>, Rest: <strong>@remainder</strong></td></tr>
                <tr><td>Rest ÷ 4</td><td>@remainder ÷ 4 = @leapAdj</td><td>Justering: <strong>@leapAdj</strong></td></tr>
                <tr><td>Summa</td><td>@((int)centuryAnchor) + @quotient + @remainder + @leapAdj = @((int)centuryAnchor + quotient + remainder + leapAdj)</td><td><strong>@((int)centuryAnchor + quotient + remainder + leapAdj)</strong></td></tr>
                <tr><td>Mod 7</td><td>@((int)centuryAnchor + quotient + remainder + leapAdj) mod 7 = @((int)doomsday)</td><td><strong>@doomsday (@((int)doomsday))</strong></td></tr>
            </tbody>
        </MudSimpleTable>
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mt-3">
            Årets Doomsday för @testYear är <MudChip T="string" Color="Color.Primary" Size="Size.Small">@doomsday</MudChip>
        </MudAlert>
    }
</MudPaper>

<div class="d-flex gap-2 mt-4">
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="learn/century-anchor" StartIcon="@Icons.Material.Filled.ArrowBack">Steg 1: Sekelankaret</MudButton>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="learn/month-doomsdays" EndIcon="@Icons.Material.Filled.ArrowForward">Steg 3: Månadsdatum</MudButton>
</div>

@code {
    private int testYear = 2024;
}
